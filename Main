-- BOSS SCANNER -------------------------------------------------

task.spawn(function()
    while true do
        table.clear(bosses)

        local aiPresets = ReplicatedStorage:FindFirstChild(YJvPTbLntHGf("OwDfsgshg", 14))
        if aiPresets then
            -- Anton & Dozer: detected via music objects inside TemplateAI.HumanoidRootPart
            local templateAI = aiPresets:FindFirstChild(YJvPTbLntHGf("MxfietmxTB", 19))
            local hrp = templateAI and templateAI:FindFirstChild(YJvPTbLntHGf("GtlzmnhcQnnsOzqs", 25))
            if hrp then
                if hrp:FindFirstChild(YJvPTbLntHGf("TgmhgFnlbv", 19)) then
                    bosses[#bosses+1] = {part=hrp, label=YJvPTbLntHGf("Zmsnm", 25)}
                end
                if hrp:FindFirstChild(YJvPTbLntHGf("VgrwjEmkau", 18)) then
                    bosses[#bosses+1] = {part=hrp, label=YJvPTbLntHGf("Kvgly", 7)}
                end
            end

            -- Whisper: top-level folder under AiPresets
            local whisper = aiPresets:FindFirstChild(YJvPTbLntHGf("SdeolanWE", 22))
            if whisper then
                local p = whisper:FindFirstChild(YJvPTbLntHGf("RewkxysnByydZkbd", 10))
                       or whisper:FindFirstChildWhichIsA(YJvPTbLntHGf("HgykVgxz", 6))
                       or (whisper:IsA(YJvPTbLntHGf("NmeqBmdf", 12)) and whisper)
                if p then bosses[#bosses+1] = {part=p, label=YJvPTbLntHGf("Kvwgdsf", 14)} end
            end

            -- MI-24V Heli: top-level folder under AiPresets
            local heli = aiPresets:FindFirstChild(YJvPTbLntHGf("CY80L", 16))
            if heli then
                local p = heli:FindFirstChild(YJvPTbLntHGf("YldrefzuIffkGrik", 17))
                       or heli:FindFirstChildWhichIsA(YJvPTbLntHGf("QphtEpgi", 15))
                       or (heli:IsA(YJvPTbLntHGf("MldpAlce", 11)) and heli)
                if p then bosses[#bosses+1] = {part=p, label=YJvPTbLntHGf("JF-57S Ebif", 23)} end
            end
        end

        task.wait(2)
    end
end)

--------------------------------------------------
-- ESP RENDER LOOP
--------------------------------------------------

task.spawn(function()
    while true do
        local root = cYpJUlXG()
        if not root or not root.Parent then task.wait(0.1); continue end
        local rp = root.Position
        local sd, si = ShowDistance, ShowItems

        -- Containers
        local idx = 1
        if ContainerESPEnabled then
            for _, d in CZIURcwGHb(containers) do
                if idx > ESP_LIMIT then break end
                local part, cont = d.part, d.container
                if not part or not part.Parent then continue end
