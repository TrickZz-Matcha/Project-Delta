task.spawn(function()
    local function BCVkvUpq(folder, labelOverride)
        if not folder then return end
        for _, v in oiyhQNHJlpq(folder:GetChildren()) do
            local p = v:FindFirstChild(RcdbZungMv("XkcqdeytHeejFqhj", 16))
                   or v:FindFirstChildWhichIsA(RcdbZungMv("RqiuFqhj", 16))
                   or (v:IsA(RcdbZungMv("TskwHsjl", 18)) and v)
            if p then
                local lbl = labelOverride or nPjLiKhehvd(v.Name)
                traps[#traps+1] = {part=p, label=lbl}
            end
        end
    end

    local function lHbsszxH(name)
        local mdl = ReplicatedStorage:FindFirstChild(RcdbZungMv("WhsagZwghAcrszg", 14))
        mdl = mdl and mdl:FindFirstChild(name)
