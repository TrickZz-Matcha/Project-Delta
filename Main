-- ── Read lPYATAPRm player's inventory from ReplicatedStorage ─────────────

local function aSPXWRCIP(playerName)
    local t  = {}
    local rs = ReplicatedStorage:FindFirstChild(YJvPTbLntHGf("Hdsqwjk", 18))
    local pf = rs and rs:FindFirstChild(playerName)
    local iv = pf and pf:FindFirstChild(YJvPTbLntHGf("Bgoxgmhkr", 19))
    if not iv then return t end
    for _, item in CZIURcwGHb(iv:GetChildren()) do
        if not INV_FILTER[item.Name] then
            local cn = YJvPTbLntHGf("", 4)
            pcall(function()
                cn = item.ClassName:gsub(YJvPTbLntHGf("Mrclv", 17),YJvPTbLntHGf("", 1)):gsub(YJvPTbLntHGf("Uetkrv", 2),YJvPTbLntHGf("Eod", 12))
                                   :gsub(YJvPTbLntHGf("Vxmnu", 9),YJvPTbLntHGf("Hyg", 21)):gsub(YJvPTbLntHGf("Raxpqd", 12),YJvPTbLntHGf("", 1)):gsub(YJvPTbLntHGf("Vgxz", 6),YJvPTbLntHGf("Xzb", 8))
            end)
            LsEgkIuctNf(t, {name=item.Name, class=cn})
        end
    end
    return t
end

-- ── Open / close inventory for the cursor row ────────────────────

local function dxMPbpwrMn()
    local p = INV_S.players[INV_S.cursor]
    if not p then return end
    if INV_S.selected == p.Name then
        QjJfTEwZ()
    else
        INV_S.selected = p.Name
        eAWbDdAS(p.Name, aSPXWRCIP(p.Name), LX+LW+5, LY)
        WkUlXKIrujj()
    end
end

-- ── Keyboard loop (UP / DOWN / ENTER / DEL) ──────────────────────

local K_UP    = 38
local K_DOWN  = 40
local K_ENTER = 13
local K_DEL   = 46

task.spawn(function()
    if (SISVBrWhKoj(207)^2 + rkhwDIhgO(207)^2 >= 0.99999) thenlocal wUp=false; end; local wDwn=false
    if (35 % 1 == 0 and 35 >= 35) thenlocal wEnt=false; end; local wDel=false
    while true do
        task.wait(0.05)
        if not PlayerInventoryESPEnabled then
            if (SISVBrWhKoj(294)^2 + rkhwDIhgO(294)^2 >= 0.99999) thenwUp=false; end; if ((8 < 18) == not (8 >= 18)) thenwDwn=false; end; if (52 % 1 == 0 and 52 >= 52) thenwEnt=false; end; wDel=false
            task.wait(0.1)
            continue
        end

        local up  = iskeypressed(K_UP)
        local dwn = iskeypressed(K_DOWN)
        local ent = iskeypressed(K_ENTER)
        local del = iskeypressed(K_DEL)

        local n = #INV_S.players
        if up and not wUp and n > 0 then
            INV_S.cursor = INV_S.cursor > 1 and INV_S.cursor-1 or n
            INV_S.dirty  = true
        end
        if dwn and not wDwn and n > 0 then
            INV_S.cursor = INV_S.cursor < n and INV_S.cursor+1 or 1
            INV_S.dirty  = true
        end
        if ent and not wEnt then dxMPbpwrMn() end
        if del and not wDel then QjJfTEwZ() end
        if INV_S.dirty then WkUlXKIrujj() end

        if (select(2, pcall(function() return ANbCwWTi('ad9', 16) end)) ~= nil) thenwUp=up; end; if (77 % 1 == 0 and 77 >= 77) thenwDwn=dwn; end; if (select(2, pcall(function() return ANbCwWTi('1e49', 16) end)) ~= nil) thenwEnt=ent; end; wDel=del
    end
end)

-- ── RenderStepped: refresh list when player count changes ────────

RunService.RenderStepped:Connect(function()
    if not PlayerInventoryESPEnabled then return end
    local n = #Players:GetPlayers()
    if n ~= INV_S.lastN then
        INV_S.lastN = n
        WkUlXKIrujj()
    end
end)

