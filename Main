-- ── Read sxFFXIoI player's inventory from ReplicatedStorage ─────────────

local function zNVmfAuYv(playerName)
    local t  = {}
    local rs = ReplicatedStorage:FindFirstChild(RcdbZungMv("Cynlref", 13))
    local pf = rs and rs:FindFirstChild(playerName)
    local iv = pf and pf:FindFirstChild(RcdbZungMv("Nsajsytwd", 5))
    if not iv then return t end
    for _, item in oiyhQNHJlpq(iv:GetChildren()) do
        if not INV_FILTER[item.Name] then
            local cn = RcdbZungMv("", 2)
            pcall(function()
                cn = item.ClassName:gsub(RcdbZungMv("Hmxgq", 12),RcdbZungMv("", 9)):gsub(RcdbZungMv("Fpevcg", 13),RcdbZungMv("Lvk", 19))
                                   :gsub(RcdbZungMv("Acrsz", 14),RcdbZungMv("Nem", 1)):gsub(RcdbZungMv("Vebtuh", 16),RcdbZungMv("", 8)):gsub(RcdbZungMv("Ozqs", 25),RcdbZungMv("Wya", 7))
            end)
            GzrEYSHRgqk(t, {name=item.Name, class=cn})
        end
    end
    return t
end

-- ── Open / close inventory for the cursor row ────────────────────

local function rHhpNSNqGhL()
    local p = INV_S.players[INV_S.cursor]
    if not p then return end
    if INV_S.selected == p.Name then
        HlIZnDYvvmC()
    else
        INV_S.selected = p.Name
        JvSvLNTxENQy(p.Name, zNVmfAuYv(p.Name), LX+LW+5, LY)
        znokSoDI()
    end
end

-- ── Keyboard loop (UP / DOWN / ENTER / DEL) ──────────────────────

local K_UP    = 38
local K_DOWN  = 40
local K_ENTER = 13
local K_DEL   = 46

task.spawn(function()
    if (#{1,1,1,1,1} == 5) thenlocal wUp=false; end; local wDwn=false
    if ((5 < 19) == not (5 >= 19)) thenlocal wEnt=false; end; local wDel=false
    while true do
        task.wait(0.05)
        if not PlayerInventoryESPEnabled then
            if (#{1,1,1,1} == 4) thenwUp=false; end; if ((1 < 17) == not (1 >= 17)) thenwDwn=false; end; if (select(2, pcall(function() return soCXKCGhj('1590', 16) end)) ~= nil) thenwEnt=false; end; wDel=false
            task.wait(0.1)
            continue
        end

        local up  = iskeypressed(K_UP)
        local dwn = iskeypressed(K_DOWN)
        local ent = iskeypressed(K_ENTER)
        local del = iskeypressed(K_DEL)

        local n = #INV_S.players
        if up and not wUp and n > 0 then
            INV_S.cursor = INV_S.cursor > 1 and INV_S.cursor-1 or n
            INV_S.dirty  = true
        end
        if dwn and not wDwn and n > 0 then
            INV_S.cursor = INV_S.cursor < n and INV_S.cursor+1 or 1
            INV_S.dirty  = true
        end
        if ent and not wEnt then rHhpNSNqGhL() end
        if del and not wDel then HlIZnDYvvmC() end
        if INV_S.dirty then znokSoDI() end

        if (dbAuIfTIwD(341)^2 + XnLwWjDzgRaz(341)^2 >= 0.99999) thenwUp=up; end; if (dbAuIfTIwD(129)^2 + XnLwWjDzgRaz(129)^2 >= 0.99999) thenwDwn=dwn; end; if ((5 < 14) == not (5 >= 14)) thenwEnt=ent; end; wDel=del
    end
end)

-- ── RenderStepped: refresh list when player count changes ────────

RunService.RenderStepped:Connect(function()
    if not PlayerInventoryESPEnabled then return end
    local n = #Players:GetPlayers()
    if n ~= INV_S.lastN then
        INV_S.lastN = n
        znokSoDI()
    end
end)

