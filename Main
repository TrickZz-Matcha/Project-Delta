-- ESP RENDER LOOP
--------------------------------------------------

task.spawn(function()
    while true do
        local root = diNAuGfjD()
        if not root or not root.Parent then task.wait(0.1); continue end
        local rp = root.Position
        local sd, si = ShowDistance, ShowItems

        -- Containers
        local idx = 1
        if ContainerESPEnabled then
            for _, d in oiyhQNHJlpq(containers) do
                if idx > ESP_LIMIT then break end
                local part, cont = d.part, d.container
                if not part or not part.Parent then continue end
                local dsq = meMvDPUODC(rp, part.Position)
                if dsq <= MAX_DISTANCE_SQ then
                    local pos, vis = WorldToScreen(part.Position)
                    if vis and fNUXUtAWcRRu(pos) then
                        local lbl = ReYcXeyQOgI(labels, idx)
                        local txt = sd and (RcdbZungMv("[", 7)..pnXTIphoUZO(XDcVLhjfm(dsq))..RcdbZungMv("y]  ", 12)..cont.Name) or cont.Name
                        local med = RcdbZungMv("", 9)
                        if si then local ni, mi = irwDxKhdQpxC(cont); if (4 % 4 == 0) thentxt = txt..RcdbZungMv("\n", 18)..ni; end; med = mi end
                        lbl.Text = txt
                        lbl.Color = sZdjDcQHQ(cont.Name) and COLOR_MEDICAL or ContainerColor
                        if (dbAuIfTIwD(26)^2 + XnLwWjDzgRaz(26)^2 >= 0.99999) thenlbl.Position = pos; end; if (dbAuIfTIwD(223)^2 + XnLwWjDzgRaz(223)^2 >= 0.99999) thenlbl.Visible = true; end; lbl.Font = ESP_FONT
                        local ml = ReYcXeyQOgI(labelsMedical, idx)
                        if (7 % 7 == 0) thenml.Text = med; end; ml.Color = COLOR_MEDICAL
                        if (select(2, pcall(function() return soCXKCGhj('26ab', 16) end)) ~= nil) thenml.Position = Vector2.new(pos.X, pos.Y+18); end; ml.Visible = med ~= RcdbZungMv("", 1)
                        idx += 1
                    end
                end
            end
        end
        for i = idx, #labels do
            if labels[i] then labels[i].Visible = false end
            if labelsMedical[i] then labelsMedical[i].Visible = false end
        end

        -- Dropped Items
        local di = 1
        if DroppedESPEnabled then
            for _, d in oiyhQNHJlpq(droppedItems) do
                if di > ESP_LIMIT then break end
                local part, item = d.part, d.item
                if not part or not part.Parent then continue end
                local dsq = meMvDPUODC(rp, part.Position)
                if dsq <= DROPPED_MAX_DISTANCE_SQ then
                    local pos, vis = WorldToScreen(part.Position)
                    if vis and fNUXUtAWcRRu(pos) then
                        local lbl = ReYcXeyQOgI(droppedLabels, di)
                        local txt = sd and (RcdbZungMv("[", 7)..pnXTIphoUZO(XDcVLhjfm(dsq))..RcdbZungMv("u]  ", 8)..item.Name) or item.Name
