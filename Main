                local cp = v:FindFirstChildWhichIsA(RcdbZungMv("AzrdOzqs", 25))
                        or (v:IsA(RcdbZungMv("JiamXizb", 8)) and v)
                if cp then
                    traps[#traps+1] = {part=cp, label=nPjLiKhehvd(name)}
                end
            end
        end
    end

    while true do
        table.clear(traps)

        local noCol = workspace:FindFirstChild(RcdbZungMv("AbPbyyvfvba", 13))
        local ncAiZ = noCol and noCol:FindFirstChild(RcdbZungMv("PxOdcth", 15))
