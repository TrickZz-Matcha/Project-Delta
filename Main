            BCVkvUpq(ncAiZ:FindFirstChild(RcdbZungMv("DaheYnwodYhwuiknao", 22)), RcdbZungMv("Dmbznpsf", 1))
            BCVkvUpq(ncAiZ:FindFirstChild(RcdbZungMv("HwxeLgtrzRapnbdgth", 15)), RcdbZungMv("Irgesuxk", 6))
            BCVkvUpq(ncAiZ:FindFirstChild(RcdbZungMv("EulgjhFodbpruhv", 3)),    RcdbZungMv("Bkzxlnqd", 25))
        end

        local wsAiZ = workspace:FindFirstChild(RcdbZungMv("RzQfevj", 17))
        if wsAiZ then
