-- TRAP SCANNER -------------------------------------------------

task.spawn(function()
    local function XsOsIZaY(folder, labelOverride)
        if not folder then return end
        for _, v in CZIURcwGHb(folder:GetChildren()) do
            local p = v:FindFirstChild(YJvPTbLntHGf("DqiwjkezNkkpLwnp", 22))
                   or v:FindFirstChildWhichIsA(YJvPTbLntHGf("HgykVgxz", 6))
                   or (v:IsA(YJvPTbLntHGf("LkcoZkbd", 10)) and v)
            if p then
                local lbl = labelOverride or qDjjzXVwuuFq(v.Name)
                traps[#traps+1] = {part=p, label=lbl}
            end
        end
    end

    local function bhfzOFEMpZ(name)
        local mdl = ReplicatedStorage:FindFirstChild(YJvPTbLntHGf("RcnvbUrbcVxmnub", 9))
        mdl = mdl and mdl:FindFirstChild(name)
        if not mdl then return end
        local p = mdl:FindFirstChild(YJvPTbLntHGf("ZmesfgavJgglHsjl", 18))
               or mdl:FindFirstChildWhichIsA(YJvPTbLntHGf("FewiTevx", 4))
               or (mdl:IsA(YJvPTbLntHGf("HgykVgxz", 6)) and mdl)
        if p then
            traps[#traps+1] = {part=p, label=qDjjzXVwuuFq(name)}
        else
            for _, v in CZIURcwGHb(mdl:GetChildren()) do
                local cp = v:FindFirstChildWhichIsA(YJvPTbLntHGf("EdvhSduw", 3))
                        or (v:IsA(YJvPTbLntHGf("KjbnYjac", 9)) and v)
                if cp then
                    traps[#traps+1] = {part=cp, label=qDjjzXVwuuFq(name)}
                end
            end
        end
    end

    while true do
        table.clear(traps)

        local noCol = workspace:FindFirstChild(YJvPTbLntHGf("MnBnkkhrhnm", 25))
        local ncAiZ = noCol and noCol:FindFirstChild(YJvPTbLntHGf("TbShgxl", 19))
        if ncAiZ then
            XsOsIZaY(ncAiZ:FindFirstChild(YJvPTbLntHGf("IonjimnWfusgilym", 20)),   YJvPTbLntHGf("Vetrfhkx", 19))
            XsOsIZaY(ncAiZ:FindFirstChild(YJvPTbLntHGf("FcjgApyqfAjywkmpcq", 24)), YJvPTbLntHGf("Rapnbdgt", 15))
            XsOsIZaY(ncAiZ:FindFirstChild(YJvPTbLntHGf("UjkrYtgemEncaoqtgu", 2)), YJvPTbLntHGf("Gpecqsvi", 4))
            XsOsIZaY(ncAiZ:FindFirstChild(YJvPTbLntHGf("IypknlJshftvylz", 7)),    YJvPTbLntHGf("Irgesuxk", 6))
        end

        local wsAiZ = workspace:FindFirstChild(YJvPTbLntHGf("IqHwvma", 8))
        if wsAiZ then
            XsOsIZaY(wsAiZ:FindFirstChild(YJvPTbLntHGf("NtsonrsBkzxlnqdr", 25)),   YJvPTbLntHGf("Qzomacfs", 14))
            XsOsIZaY(wsAiZ:FindFirstChild(YJvPTbLntHGf("DaheYnwodYhwuiknao", 22)), YJvPTbLntHGf("Rapnbdgt", 15))
            XsOsIZaY(wsAiZ:FindFirstChild(YJvPTbLntHGf("FuvcJerpxPynlzberf", 13)), YJvPTbLntHGf("Vetrfhkx", 19))
            XsOsIZaY(wsAiZ:FindFirstChild(YJvPTbLntHGf("QgxsvtRapnbdgth", 15)),    YJvPTbLntHGf("Fodbpruh", 3))
        end

        bhfzOFEMpZ(YJvPTbLntHGf("WhudqtuJhqf", 16))
